<?php

/**
 * @file
 * Contains code for Navigation Test.
 */

use Drupal\Core\Url;

/**
 * Implements hook_preprocess_HOOK() for block.
 */
function cd_navigation_preprocess_block(&$variables) {
  if (
    $variables['plugin_id'] === 'system_main_block' &&
    \Drupal::routeMatch()->getRouteName() === 'system.admin'
  ) {
    // Add compact mode switcher link to the '/admin' page's page content block.
    if (!empty($variables['content']['#markup'])) {
      $variables['content']['original'] = [
        '#markup' => $variables['content']['#markup'],
        '#weight' => 1,
      ];
      unset($variables['content']['#markup']);

      $variables['content']['system_compact_link'] = [
        '#type' => 'system_compact_link',
        '#weight' => 0,
      ];
    }
  }
}

/**
 * Implements hook_toolbar().
 */
function cd_navigation_toolbar() {
  $items['cd_navigation_config'] = [
    '#type' => 'toolbar_item',
    'tab' => [
      '#type' => 'link',
      '#title' => t('Nav Config'),
      '#url' => Url::fromRoute('cd_navigation.configtest'),
    ],
    '#weight' => 105,
  ];
  $items['cd_navigation_admin_tasks'] = [
    '#type' => 'toolbar_item',
    'tab' => [
      '#type' => 'link',
      '#title' => t('Nav Tasks'),
      '#url' => Url::fromRoute('system.admin'),
    ],
    '#weight' => 106,
  ];

  return $items;
}
